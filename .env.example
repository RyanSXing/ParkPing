# Required Supabase project settings.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Free MVP default. Use simulated unless a real delivery provider is implemented.
NOTIFICATION_MODE=simulated

# Used to build secure owner resolve links.
APP_BASE_URL=http://localhost:3000

# Used to hash requester signals for rate limiting without storing raw identity.
REQUESTER_HASH_SECRET=

# Comma-separated Supabase Auth emails allowed to access /admin.
ADMIN_EMAILS=admin@example.com

# Optional future live notification settings. Not required in simulated mode.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
RESEND_API_KEY=
FROM_EMAIL=
